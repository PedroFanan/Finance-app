# ─── API (apps/api/.env) ──────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL externo (Supabase ou Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT
JWT_ACCESS_SECRET="troque-por-uma-chave-forte-aleatoria"
JWT_REFRESH_SECRET="troque-por-outra-chave-forte-aleatoria"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Upload de fotos
UPLOAD_PROVIDER=local
UPLOAD_LOCAL_PATH="./uploads"

# CORS (separado por vírgula)
CORS_ORIGIN="http://localhost:3000"

# ─── WEB (apps/web/.env.local) ────────────────────────────────────────────────

NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_NAME="Finance App"
